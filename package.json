{
  "name": "pi-usereq",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/**/*.test.ts",
    "cli": "node --import tsx ./src/cli.ts",
    "debug:ext": "node --import tsx ./scripts/debug-extension.ts",
    "debug:ext:inspect": "node --import tsx ./scripts/debug-extension.ts inspect",
    "debug:ext:session": "node --import tsx ./scripts/debug-extension.ts session-start",
    "debug:ext:command": "node --import tsx ./scripts/debug-extension.ts command",
    "debug:ext:tool": "node --import tsx ./scripts/debug-extension.ts tool",
    "debug:ext:sdk": "node --import tsx ./scripts/debug-extension.ts sdk-smoke"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "^0.34.49"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "js-tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
